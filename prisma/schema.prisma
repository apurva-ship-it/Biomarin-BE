generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  firstName          String
  lastName           String
  displayName        String?
  avatarUrl          String?
  title              String?
  department         String?
  location           String?
  role               String   @default("viewer")
  status             String   @default("active")
  passwordHash       String?
  phone              String?
  teamsHandle        String?
  bio                String?
  availabilityStatus String   @default("available")
  lastLoginAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  reportsToId        String?
  reportsTo          User?    @relation("OrgHierarchy", fields: [reportsToId], references: [id])
  directReports      User[]   @relation("OrgHierarchy")
  orgLevel           Int      @default(0)

  skills             UserSkill[]
  interests          UserInterest[]
  tools              UserTool[]
  sessions           UserSession[]
  notifications      Notification[]
  pinnedResources    PinnedResource[]
  courseProgress     UserCourseProgress[]
  contributions      UserContribution[]
  projects           UserProject[]
  aiConversations    AiConversation[]
  managedInitiatives InitiativeTeamMember[]
  createdInitiatives Initiative[]   @relation("CreatedBy")
  createdResources   Resource[]     @relation("CreatedBy")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model UserSkill {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill    String
  category String @default("technical")

  @@unique([userId, skill])
}

model UserInterest {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  interest String

  @@unique([userId, interest])
}

model UserTool {
  id       String  @id @default(uuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolName String
  iconUrl  String?

  @@unique([userId, toolName])
}

model Announcement {
  id           String    @id @default(uuid())
  title        String
  description  String?
  content      String?
  category     String    @default("announcement")
  thumbnailUrl String?
  authorId     String?
  team         String?
  publishedAt  DateTime?
  isFeatured   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Tool {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String?
  icon        String?
  externalUrl String?
  usageCount  Int      @default(0)
  isTrending  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InitiativeCategory {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  description String?
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  initiatives Initiative[]
}

model Initiative {
  id               String               @id @default(uuid())
  title            String
  slug             String               @unique
  subtitle         String?
  description      String?
  categoryId       String?
  category         InitiativeCategory?  @relation(fields: [categoryId], references: [id])
  status           String               @default("active")
  impactLevel      String               @default("medium")
  isTrending       Boolean              @default(false)
  isNew            Boolean              @default(false)
  startDate        DateTime?
  targetLaunchDate DateTime?
  teamName         String?
  icon             String?
  createdById      String?
  createdBy        User?                @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  tags             InitiativeTag[]
  teamMembers      InitiativeTeamMember[]
  objectives       InitiativeObjective[]
  updates          InitiativeUpdate[]
  capabilities     InitiativeCapability[]
  saves            InitiativeSave[]
  resources        ResourceInitiativeLink[]
  userProjects     UserProject[]
}

model InitiativeTag {
  id           String     @id @default(uuid())
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  tag          String
  color        String?

  @@unique([initiativeId, tag])
}

model InitiativeTeamMember {
  id           String     @id @default(uuid())
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         String?
  joinedAt     DateTime   @default(now())

  @@unique([initiativeId, userId])
}

model InitiativeObjective {
  id           String     @id @default(uuid())
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  title        String
  isCompleted  Boolean    @default(false)
  sortOrder    Int        @default(0)
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
}

model InitiativeUpdate {
  id           String     @id @default(uuid())
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  title        String
  body         String?
  authorId     String?
  isPinned     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model InitiativeCapability {
  id           String     @id @default(uuid())
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  name         String

  @@unique([initiativeId, name])
}

model InitiativeSave {
  userId       String
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  savedAt      DateTime   @default(now())

  @@id([userId, initiativeId])
}

model Resource {
  id            String   @id @default(uuid())
  title         String
  description   String?
  type          String   @default("document")
  fileUrl       String?
  fileName      String?
  fileSizeBytes Int?
  mimeType      String?
  thumbnailUrl  String?
  department    String?
  createdById   String?
  createdBy     User?    @relation("CreatedBy", fields: [createdById], references: [id])
  isFeatured    Boolean  @default(false)
  downloadCount Int      @default(0)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tags          ResourceTag[]
  initiatives   ResourceInitiativeLink[]
  pinnedBy      PinnedResource[]
  embeddings    DocumentEmbedding[]
}

model ResourceTag {
  id         String   @id @default(uuid())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  tag        String

  @@unique([resourceId, tag])
}

model ResourceInitiativeLink {
  resourceId   String
  resource     Resource   @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@id([resourceId, initiativeId])
}

model PinnedResource {
  userId     String
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pinnedAt   DateTime @default(now())

  @@id([userId, resourceId])
}

model Notification {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  type          String   @default("system")
  referenceType String?
  referenceId   String?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Course {
  id               String   @id @default(uuid())
  title            String
  description      String?
  category         String?
  thumbnailUrl     String?
  totalModules     Int      @default(0)
  estimatedMinutes Int?
  isPublished      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  modules          CourseModule[]
  progress         UserCourseProgress[]
}

model CourseModule {
  id              String   @id @default(uuid())
  courseId        String
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  contentUrl      String?
  sortOrder       Int      @default(0)
  durationMinutes Int?
  createdAt       DateTime @default(now())
}

model UserCourseProgress {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  currentModuleId String?
  progressPercent Float     @default(0)
  startedAt       DateTime  @default(now())
  completedAt     DateTime?

  @@unique([userId, courseId])
}

model WorkshopSession {
  id              String   @id @default(uuid())
  title           String
  description     String?
  scheduledAt     DateTime
  durationMinutes Int?
  location        String?
  instructorId    String?
  maxAttendees    Int?
  createdAt       DateTime @default(now())

  registrations   WorkshopRegistration[]
}

model WorkshopRegistration {
  userId       String
  sessionId    String
  session      WorkshopSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  registeredAt DateTime @default(now())

  @@id([userId, sessionId])
}

model AiConversation {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  messages  AiMessage[]
}

model AiMessage {
  id             String         @id @default(uuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  sources        String?
  feedback       String?
  feedbackText   String?
  createdAt      DateTime       @default(now())
}

model DocumentEmbedding {
  id         String   @id @default(uuid())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  chunkIndex Int
  chunkText  String
  metadata   String?
  createdAt  DateTime @default(now())
}

model UserProject {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  initiativeId String
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  role         String
  description  String?
  isActive     Boolean    @default(true)
  joinedAt     DateTime   @default(now())
}

model UserContribution {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  title         String?
  description   String?
  referenceType String?
  referenceId   String?
  createdAt     DateTime @default(now())
}
